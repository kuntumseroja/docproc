# Application
APP_NAME=DocProc API
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://docproc:docproc@localhost:5432/docproc

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docproc
MINIO_USE_SSL=false

# JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM Provider: anthropic | openai | ollama | mistral | deepseek
LLM_PROVIDER=anthropic
LLM_MODEL=

# Fallback provider when primary hits rate limits (optional)
LLM_FALLBACK_PROVIDER=deepseek

# API Keys (set the one matching your LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# Ollama (on-prem)
OLLAMA_BASE_URL=http://localhost:11434

# OCR Provider: tesseract | mistral
OCR_PROVIDER=tesseract
TESSERACT_PATH=tesseract

# CORS
CORS_ORIGINS=["http://localhost:3000"]
